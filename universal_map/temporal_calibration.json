  "distance_measures": {
    "comoving_distance": {
      "description": "Distance between two objects at the same redshift, accounting for expansion",
      "formula": "D_C = c * integral_0^z dz' / H(z')",
      "units": "Mpc/h"
    },
    "lookback_time": {
      "description": "Time elapsed since light was emitted from an object at redshift z",
      "formula": "t_L = integral_0^z dz' / ((1+z') * H(z'))",
      "units": "Gyr"
    },
    "luminosity_distance": {
      "description": "Distance inferred from observed flux of standard candles",
      "formula": "D_L = (1+z) * D_C",
      "units": "Mpc"
    },
    "angular_diameter_distance": {
      "description": "Distance inferred from apparent angular size of objects",
      "formula": "D_A = D_C / (1+z)",
      "units": "Mpc"
    }
  },
